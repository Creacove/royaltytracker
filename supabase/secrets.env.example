# Secrets for Supabase Edge Functions (do not commit real values).
#
# Apply to remote:
#   supabase secrets set --env-file supabase/secrets.env
#
# Required by `supabase/functions/process-report`:
GOOGLE_CLOUD_PROJECT=REPLACE_ME
DOCUMENTAI_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_KEY=REPLACE_ME_JSON

# Required by billing/paywall edge functions:
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME
APP_ORIGIN=http://localhost:8080
